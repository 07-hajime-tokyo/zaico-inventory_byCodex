# Local server
PORT=3000
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE?ssl={"rejectUnauthorized":true}
JWT_SECRET=replace-with-a-long-random-secret

# Local email login
# Admin emails are also defined in shared/const.ts. Add extra allowed users here.
AUTH_ALLOWED_EMAILS=operator-a@example.com,operator-b@example.com

# Local operator labels
ZAICO_OPERATOR_DEFAULT_NAME=Noda
ZAICO_OPERATOR_DEFAULT_EMAIL=default@example.com
ZAICO_OPERATOR_A_NAME=Operator A
ZAICO_OPERATOR_A_EMAIL=operator-a@example.com
ZAICO_OPERATOR_B_NAME=Operator B
ZAICO_OPERATOR_B_EMAIL=operator-b@example.com

# Optional: only needed if Zaico API integration is deliberately turned back on.
# Zaico is not required for normal local DB operation.
# ZAICO_API_TOKEN=
# ZAICO_OPERATOR_A_TOKEN=
# ZAICO_OPERATOR_B_TOKEN=

# GAS / Google Sheets webhook integration
GAS_WEBHOOK_SECRET=replace-with-shared-webhook-secret
GAS_WEBHOOK_URL=https://your-app.example.com/api/gas-webhook/register-product

# External access-code checker CORS origins
VERIFY_CODE_ALLOWED_ORIGINS=https://your-csv-search.example.com

# Optional owner notification webhook for partner portal messages
OWNER_NOTIFICATION_WEBHOOK_URL=

# GitHub CSV integration
GITHUB_CSV_TOKEN=github-token-with-read-access
GITHUB_CSV_URL=https://raw.githubusercontent.com/07-hajime-tokyo/csv-data-site/main/data.csv

# Optional external integration tests
RUN_ZAICO_OPERATOR_TESTS=false
RUN_GITHUB_CSV_TESTS=false
